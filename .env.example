# Copy to .env and fill in. The Reflex app reads these at runtime.

# --- LLM (Claude) ---
# Required. Used to turn transcripts into per-segment visual search queries.
ANTHROPIC_API_KEY=sk-ant-...

# --- Media search (stock APIs) ---
# Required. Free keys:
#   Pexels:  https://www.pexels.com/api/
#   Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Google sign-in (OAuth) ---
# Optional. Create an OAuth 2.0 Client (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add this authorized
# redirect URI: http://localhost:8000/auth/google/callback
# The "Sign in with Google" button activates once both values are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional overrides if not running on the default localhost ports:
# FRONTEND_URL=http://localhost:3000
# BACKEND_URL=http://localhost:8000
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Database ---
# Optional. Defaults to local SQLite (sqlite:///reflex.db) when unset.
# For production, point at Postgres, e.g.:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/audiomedia
# DATABASE_URL=

# --- Transcription (faster-whisper) ---
# Optional. Model size: tiny | base | small | medium | large-v3 (default: base).
# Larger = more accurate but slower; downloaded on first run.
# WHISPER_MODEL_SIZE=base

# Optional. A Hugging Face access token silences the "unauthenticated requests
# to the HF Hub" warning during model download and grants higher rate limits.
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
# HF_TOKEN=hf_...
